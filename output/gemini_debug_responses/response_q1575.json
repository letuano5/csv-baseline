            "code": "import pandas as pd\nimport json\n\n# Load the dataset\ndf = pd.read_csv('input_file_0.csv')\n\n# Define numeric columns to cast\nnumeric_cols = [\n    'Total Assets', 'Number of Employees', 'Year'\n]\n\n# Function to clean Vietnamese numeric strings\ndef clean_numeric(val):\n    if pd.isna(val):\n        return val\n    if isinstance(val, str):\n        # Remove dots (potential thousand separators)\n        # But wait, if there's a comma, the dot is definitely a separator.\n        # If there's no comma, a dot might be a decimal. \n        # Looking at \"1124,04\", comma is decimal.\n        # Looking at \"443.605.638\", dots are separators.\n        val = val.replace('.', '')\n        val = val.replace(',', '.')\n    return val\n\nfor col in numeric_cols:\n    df[col] = df[col].apply(clean_numeric)\n    df[col] = pd.to_numeric(df[col], errors='coerce')\n\n# Filter: Total Assets > 1,000,000\nfiltered_df = df[df['Total Assets'] > 1000000].copy()\n\n# Sort: Year DESC, Total Assets DESC\nfiltered_df = filtered_df.sort_values(by=['Year', 'Total Assets'], ascending=[False, False])\n\n# Select columns in order: Bank Code, Year, Total Assets, Number of Employees\nresult_df = filtered_df[['Bank Code', 'Year', 'Total Assets', 'Number of Employees']]\n\n# Format the Total Assets and Number of Employees to avoid scientific notation and limit decimals\n# result_df['Total Assets'] = result_df['Total Assets'].round(2)\n# Number of Employees is usually int, but handle as float for 2 decimal places if needed.\n# Converting to list for JSON output\n\n# Convert to list of lists\nresult_list = result_df.values.tolist()\n\n# Apply the 2 decimal places rounding to the result\nfinal_result = []\nfor row in result_list:\n    new_row = []\n    for item in row:\n        if isinstance(item, float):\n            if pd.isna(item):\n                new_row.append(None)\n            else:\n                new_row.append(round(item, 2))\n        else:\n            new_row.append(item)\n    final_result.append(new_row)\n\nprint(json.dumps(final_result, ensure_ascii=False))\n",
            "language": "Language.PYTHON",
            "id": null
          }
        },
