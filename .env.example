# Anthropic — thêm _2, _3 ... nếu có nhiều keys
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY_1=sk-ant-...
# ANTHROPIC_API_KEY_2=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_1=sk-...
# OPENAI_API_KEY_2=sk-...

# Google Gemini — chọn một trong hai cách auth:

# Cách 1: API key (Gemini Developer API)
GOOGLE_API_KEY=AIza...
# GOOGLE_API_KEY_1=AIza...

# Cách 2: Vertex AI (GCP) — nếu set thì runner tự dùng Vertex, bỏ qua API key
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global

# OpenRouter (https://openrouter.ai) — Chat Completions; use with --provider openrouter
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_API_KEY_1=sk-or-v1-...
# Optional: OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: OPENROUTER_HTTP_REFERER=https://yoursite.example
# Optional: OPENROUTER_APP_TITLE=csv-baseline
# GOOGLE_API_KEY_2=AIza...
